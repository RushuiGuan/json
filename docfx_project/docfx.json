{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "..",
          "files": [
            "Albatross.Json/Albatross.Json.csproj"
          ]
        }
      ],
      "output": "api"
    }
  ],
  "build": {
    "sitemap": {
      "baseUrl": "https://rushuiguan.github.io/json",
      "priority": 0.5,
      "changefreq": "weekly"
    },
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**",
          "*.html",
          "robots.txt",
          ".nojekyll"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "Albatross.Json",
      "_appTitle": "Path-based JSON value manipulation for System.Text.Json",
      "_appLogoPath": "./images/logo.svg",
      "_appFaviconPath": "./images/favicon.svg",
      "_enableSearch": true,
      "pdf": false,
      "_gitContribute": {
        "repo": "https://github.com/rushuiguan/json",
        "branch": "main",
        "path": "docfx_project"
      },
      "_gitUrlPattern": "github"
    }
  }
}